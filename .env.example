# Copy to .env and fill in your values

# PostgreSQL
POSTGRES_DB=fs_template
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# API — used for local development (drizzle-kit, seed, etc.)
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/fs_template

# API server
PORT=3001
NODE_ENV=development

# Seed script — run once to create the first SUPER_ADMIN
SEED_EMAIL=admin@example.com
SEED_PASSWORD=P@ssw0rd
SEED_FIRST_NAME=System
SEED_LAST_NAME=Admin
