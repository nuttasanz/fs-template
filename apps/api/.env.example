# Copy to .env and fill in your values

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/fs_template

# Server
PORT=3001
NODE_ENV=development

# Security — required in all environments
# Generate SESSION_SECRET with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-random-64-char-hex-string
ALLOWED_ORIGINS=http://localhost:3000

# Seed script — used once to create the first SUPER_ADMIN
SEED_EMAIL=admin@example.com
SEED_PASSWORD=P@ssw0rd
SEED_FIRST_NAME=System
SEED_LAST_NAME=Admin
